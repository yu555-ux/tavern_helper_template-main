/* --- 针对小屏幕 (例如 max-width: 768px) --- */
/* ====================================================================== */
/* ===   STYLES FOR SCREENS 768px AND NARROWER                        === */
/* ====================================================================== */
@media (max-width: 768px) {
    .game-container {
        display: flex;
        flex-direction: column;
        width: 100%;
        /* height: 100%; /* 移除或设为auto，让SillyTavern或内容决定总高度 */
        /* max-height: none; /* 同上 */
        overflow: hidden; /* 确保子元素溢出时容器本身裁剪 */
        border-radius: 0;
        border: none;
        border-image: none;
        box-shadow: none;
    }

    /* --- 1. Status Bar --- */
    #status-bar {
        order: 1;
        flex-shrink: 0; /* 不收缩 */
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        padding: 0.4em 0.8em;
        gap: 0.2em;
        border-bottom: 1px solid var(--primary-color);
    }
    #status-bar > div {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.3em 0.7em;
        width: 100%;
    }

    /* --- 2. Side Navigation (Now as a Top Nav Bar) --- */
    #side-nav {
        order: 2; /* 放置在 Status Bar 之后 */
        flex-shrink: 0; /* 不收缩 */
        width: 100%; /* 占据全部宽度 */
        flex-direction: row; /* 按钮横向排列 */
        overflow-x: auto;    /* 如果按钮过多，允许横向滚动 */
        overflow-y: hidden;
        background-color: rgba(10, 8, 5, 0.85); /* 深色背景以区分 */
        border-right: none; /* 移除之前的右边框 */
        border-top: none; /* 如果之前有顶部边框，移除 */
        border-bottom: 1px solid var(--primary-color); /* 在导航栏下方添加分隔线 */
        padding: 0.4em; /* 导航栏本身的内边距 */
        justify-content: flex-start; /* 按钮从左开始排列，或者用 space-around 平均分布 */
        gap: 0.5em; /* 按钮之间的间隙 */
    }
    #side-nav button {
        width: auto; /* 按钮宽度自适应内容 */
        min-width: auto; /* 允许按钮根据内容和可用空间调整，而不是固定最小宽度 */
        flex: 0 0 auto;  /* 不放大，不缩小，基于内容宽度 */
        font-size: 0.9em;
        padding: 0.6em 0.8em; /* 调整按钮内边距以适应横向排列 */
        /* border: 1px solid var(--border-color-medium); /* 可选，按钮边框 */
        /* border-radius: var(--button-border-radius); */
    }
    #side-nav button i {
        margin-right: 6px; /* 图标和文字的间距 */
    }

    /* --- 3. Main Content Area --- */
    #main-content-area {
        order: 3; /* 放置在 Side Nav 之后 */
        flex-grow: 1; /* 占据所有剩余垂直空间 */
        min-height: 0; /* 关键：允许其内部内容滚动，而不是撑开父容器 */
        display: flex; /* 使其成为flex容器，以便其子元素可以填充 */
        flex-direction: column;
        overflow: hidden; /* #main-console-panel 将处理自己的溢出 */
        padding: 0; /* 移除外层padding，让#main-output控制内容区的padding */
    }
    /* Ensure .main-panel (like #main-console-panel) fills #main-content-area */
    .main-panel.active {
        position: relative; /* 从 absolute 改为 relative 或 static */
        flex-grow: 1;
        min-height: 0;
        display: flex;
        flex-direction: column;
        /* 清理绝对定位残留 */
        top: auto; left: auto; right: auto; bottom: auto; width:auto; height:auto;
        opacity: 1; /* 确保可见 */
        pointer-events: auto; /* 确保可交互 */
    }
    /* #main-console-panel 应该已经是 flex-grow: 1 了 */
    #main-output {
        position: relative; /* 从 absolute 改为 relative 或 static */
        flex-grow: 1;     /* 占据 #main-console-panel 的所有可用空间 */
        min-height: 0;    /* 允许自身内容滚动 */
        /* 清理绝对定位残留 */
        top: auto; left: auto; right: auto; bottom: auto;
        /* 现在在这里设置内边距 */
        padding: 1em;
        padding-right: 1.2em; /* 为滚动条留出空间 */
        /* overflow-y: auto; 应该已经存在，确保主叙事文本可以滚动 */
        /* white-space: pre-wrap; line-height: 1.7; font-size: 1.1em; text-shadow... etc. 保持 */
    }

    /* --- 4. Input Area --- */
    #input-area {
        order: 4; /* 保持在最底部 */
        flex-shrink: 0; /* 不收缩 */
        /* padding, gap 等可按需调整 */
    }

    /* Overlay panel adjustments (基本保持，因为它们是独立的覆盖层) */
    .overlay-panel {
        width: 98%; /* 在小屏幕上几乎占满 */
        height: 95%;
        /* border-image: ...保持 */
    }
    #tilemap-overlay .tile-info-panel {
        max-height: 160px; /* 地图信息面板高度限制 */
    }
    #llm-options {
        max-height: 10em; /* LLM 选项按钮区域高度 */
    }
}

/* ====================================================================== */
/* ===   STYLES FOR SCREENS 480px AND NARROWER                        === */
/* ====================================================================== */
@media (max-width: 480px) {
    /* Status Bar Refinements */
    #status-bar {
        padding: 0.3em 0.6em;
        font-size: 0.85em;
    }
    #status-bar > div {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.2em; /* 之前是0.3em，可以根据喜好调整 */
    }

    /* Top Navigation Bar (was Side Nav) Refinements */
    #side-nav {
        padding: 0.3em; /* 导航栏本身的内边距再小一点 */
        gap: 0.3em;     /* 按钮间隙再小一点 */
    }
    #side-nav button {
        padding: 0.5em 0.5em; /* 按钮内边距进一步减小 */
        font-size: 0.8em;    /* 按钮字体更小 */
    }
    #side-nav button i {
        margin-right: 4px;
    }

    /* Main Output Area Refinements */
    #main-output {
        padding: 0.8em;       /* 主叙事区域内边距减小 */
        font-size: 1em;       /* 调整字体，但不要太小 */
        line-height: 1.6;
    }

    /* Input Area Refinements */
    #llm-options {
        max-height: 8em;      /* 进一步限制LLM选项按钮区域的最大高度 */
    }
    #llm-options button {
        font-size: 0.85em;
        padding: 0.5em 0.8em;
        min-width: auto; /* 允许按钮变得更窄 */
    }

    #player-input-container { /* 已在768px设为column，这里可微调 */
        flex-direction: column;
        gap: 0.5em;
    }
    #player-input-container input[type="text"]{
         font-size: 0.95em;
         padding: 0.7em 0.9em;
    }
    #player-input-container button {
        padding: 0.7em 1em; /* 确认按钮的内边距 */
        font-size: 0.9em;
    }

    /* Overlay Panels - 在极小屏幕上通常使其全屏化 */
    .overlay-panel {
        width: 100%;
        height: 100%;
        max-width: 100%;
        max-height: 100%;
        border-radius: 0;
        border: none; /* 在480px下可以考虑完全移除边框 */
        box-shadow: none; /* 也可以考虑移除阴影 */
    }
    .overlay-title-bar {
        padding: 0.6em 1em;
    }
    .overlay-title-bar h2 {
        font-size: 1.1em;
    }
    .overlay-title-bar h2 i {
        font-size: 0.85em;
    }
    .overlay-close-btn {
        font-size: 1.5em;
        padding: 0 6px;
    }
    .overlay-content {
        padding: calc(var(--spacing-unit) * 0.6);
    }
    #tilemap-overlay .tile-info-panel {
        max-height: 120px; /* 地图信息面板可以更矮 */
        font-size: 0.85em;
    }
}

