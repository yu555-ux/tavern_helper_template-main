            document.querySelectorAll('.overlay-container.active').forEach(activeOverlay => { if (activeOverlay.id !== overlayId) activeOverlay.classList.remove('active'); });
            document.getElementById('main-console-panel').classList.remove('active');
            overlayToOpen.classList.add('active');
            document.querySelectorAll('#side-nav button').forEach(btn => btn.classList.remove('active'));
            const triggerButton = document.querySelector(`#side-nav button[data-overlay-id="${overlayId}"], button.overlay-trigger[data-overlay-id="${overlayId}"]`);
            if (triggerButton && triggerButton.closest('#side-nav')) triggerButton.classList.add('active');
            const tileInteractionPanel = document.getElementById('tile-interaction-panel');
            if (tileInteractionPanel && tileInteractionPanel.classList.contains('visible')) tileInteractionPanel.classList.remove('visible');
